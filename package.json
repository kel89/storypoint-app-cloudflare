{
  "name": "storypointer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:worker": "wrangler dev",
    "dev:frontend": "cd front-end && npm run dev",
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:frontend\"",
    "build": "cd front-end && npm run build",
    "deploy": "cd front-end && npm run build && cd .. && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
